{
  "name": "pnl-calendar",
  "version": "1.0.0",
  "description": "Editable profit & loss calendar desktop app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.pnlcalendar.app",
    "productName": "PNL Calendar",
    "directories": {
      "output": "dist"
    },
    "icon": "assets/icon.png",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    }
  }
}
